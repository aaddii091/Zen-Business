---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Responsible Use — Zengarden"
      description="How Zengarden ensures structured, responsible, and confidential student support. Aligned with national mental health guidelines."
    />
  </head>
  <body>
    <Header />

    <main class="ru-main">
      <div class="ru-container">

        <h1 class="ru-title">Responsible Use</h1>
        <p class="ru-subtitle">Aligned with national student mental health guidelines and institutional best practices</p>

        <div class="ru-columns">

          <!-- Left: three info sections -->
          <div class="ru-left">
            <div class="ru-section">
              <div class="ru-section-heading-wrap">
                <span class="ru-heading-icon" aria-hidden="true">
                  <svg width="65" height="65" viewBox="0 0 65 65" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.541 39.2705C13.541 39.2705 17.6035 39.2705 23.0202 48.7497C23.0202 48.7497 38.0758 23.9224 51.4577 18.958" stroke="#00BBA1" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <h2 class="ru-section-heading">What Zengarden enables</h2>
              </div>
              <div class="ru-items">
                <p class="ru-item">Early awareness through structured questionnaires</p>
                <p class="ru-item">Guided support pathways based on student's needs</p>
                <p class="ru-item">Access to mentors and qualified psychologists</p>
                <p class="ru-item">Confidential and continuous institutional support</p>
              </div>
            </div>

            <div class="ru-section">
              <div class="ru-section-heading-wrap">
                <span class="ru-heading-icon" aria-hidden="true">
                  <svg width="58" height="56" viewBox="0 0 58 56" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M26.0677 29.6193L22.1406 25.76C21.6441 25.2634 21.0239 25.0152 20.28 25.0152C19.5361 25.0152 18.8924 25.286 18.349 25.8277C17.8524 26.3242 17.6042 26.9561 17.6042 27.7235C17.6042 28.4909 17.8524 29.1228 18.349 29.6193L24.1719 35.4422C24.7135 35.9839 25.3455 36.2547 26.0677 36.2547C26.7899 36.2547 27.4219 35.9839 27.9635 35.4422L39.474 23.9318C40.0156 23.3902 40.2747 22.7582 40.2513 22.036C40.2278 21.3138 39.9687 20.6818 39.474 20.1402C38.9323 19.5985 38.2895 19.3168 37.5456 19.2952C36.8017 19.2735 36.1581 19.5326 35.6146 20.0725L26.0677 29.6193ZM18.4844 54.1298L14.5573 47.4943L7.10938 45.8693C6.43229 45.7339 5.89062 45.3845 5.48437 44.8212C5.07812 44.2579 4.92014 43.6368 5.01042 42.9579L5.75521 35.3068L0.677083 29.4839C0.225694 28.9874 0 28.4006 0 27.7235C0 27.0464 0.225694 26.4596 0.677083 25.9631L5.75521 20.1402L5.01042 12.4891C4.92014 11.812 5.07812 11.1909 5.48437 10.6258C5.89062 10.0606 6.43229 9.71127 7.10938 9.57766L14.5573 7.95266L18.4844 1.31725C18.8455 0.73044 19.342 0.335023 19.974 0.130995C20.6059 -0.0730327 21.2378 -0.0387271 21.8698 0.233912L28.9115 3.21308L35.9531 0.233912C36.5851 -0.0369216 37.217 -0.0712271 37.849 0.130995C38.4809 0.333217 38.9774 0.728634 39.3385 1.31725L43.2656 7.95266L50.7135 9.57766C51.3906 9.71308 51.9323 10.0634 52.3385 10.6285C52.7448 11.1936 52.9028 11.8138 52.8125 12.4891L52.0677 20.1402L57.1458 25.9631C57.5972 26.4596 57.8229 27.0464 57.8229 27.7235C57.8229 28.4006 57.5972 28.9874 57.1458 29.4839L52.0677 35.3068L52.8125 42.9579C52.9028 43.635 52.7448 44.2561 52.3385 44.8212C51.9323 45.3863 51.3906 45.7357 50.7135 45.8693L43.2656 47.4943L39.3385 54.1298C38.9774 54.7166 38.4809 55.112 37.849 55.316C37.217 55.52 36.5851 55.4857 35.9531 55.2131L28.9115 52.2339L21.8698 55.2131C21.2378 55.4839 20.6059 55.5182 19.974 55.316C19.342 55.1138 18.8455 54.7184 18.4844 54.1298Z" fill="#00BBA1"/></svg>
                </span>
                <h2 class="ru-section-heading">Scientific Foundation</h2>
              </div>
              <div class="ru-items">
                <p class="ru-item">Supported by MPhil, RCI Certified psychologists</p>
                <p class="ru-item">Built on Big Five (OCEAN) and 16PF</p>
              </div>
            </div>

            <div class="ru-section">
              <div class="ru-section-heading-wrap">
                <span class="ru-heading-icon" aria-hidden="true">
                  <svg width="45" height="45" viewBox="0 0 45 45" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M37.5 37.5L7.5 7.5M37.5 7.5L7.5 37.5" stroke="#FF0000" stroke-opacity="0.62" stroke-width="4" stroke-linecap="round"/></svg>
                </span>
                <h2 class="ru-section-heading">Clear Boundaries</h2>
              </div>
              <div class="ru-items">
                <p class="ru-item">Not a diagnostic tool</p>
                <p class="ru-item">Not a substitute for emergency care</p>
                <p class="ru-item">Supports informed decisions, not prescriptions</p>
              </div>
            </div>
          </div>

          <!-- Right: priority system card -->
          <div class="ru-right">
            <div class="ru-card-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="65" height="65" viewBox="0 0 24 24">
                <path fill="currentColor" d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
              </svg>
            </div>
            <h2 class="ru-card-heading">Intelligent Priority System</h2>
            <p class="ru-card-tagline">We recommend. Students decide.</p>
            <div class="ru-card-items">
              <p class="ru-card-item">Zengarden ensures the right students receive attention at the right time.</p>
              <p class="ru-card-item">Students are prioritised based on their questionnaire responses</p>
              <p class="ru-card-item">Levels of need are clearly defined</p>
              <p class="ru-card-item">The system recommends the most appropriate support</p>
              <p class="ru-card-item">Urgent cases are prioritised for faster intervention</p>
            </div>
          </div>

        </div>

        <p class="ru-tagline">Zengarden helps institutions move from reactive intervention to structured, preventive care</p>

      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .ru-main {
    padding: 56px 0 148px;
    background: #fff;
  }

  .ru-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 84px;
  }

  /* Title: centered, 36px/700, lineHeight 57px */
  .ru-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--zg-mid);
    text-align: center;
    margin: 0 0 24px;
    line-height: 57px;
  }

  /* Subtitle: centered, 24px/500, --zg-muted */
  .ru-subtitle {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--zg-muted);
    text-align: center;
    margin: 0 0 28px;
    line-height: 34px;
  }

  /* Two-column grid matching Figma 584px / 81px gap / 588px */
  .ru-columns {
    display: grid;
    grid-template-columns: 584fr 588fr;
    gap: 81px;
    align-items: start;
    margin-bottom: 28px;
  }

  /* ── Left column ── */
  .ru-left {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .ru-section-heading-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .ru-heading-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    width: 52px;
    justify-content: center;
  }

  .ru-section-heading {
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0;
    line-height: 41px;
  }

  .ru-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ru-item {
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--zg-dark);
    line-height: 41px;
    margin: 0;
  }

  /* ── Right card ── */
  .ru-right {
    background: var(--zg-light-bg);
    border-radius: 20px;
    padding: 40px 44px;
  }

  .ru-card-icon {
    color: var(--zg-blue);
    margin-bottom: 20px;
  }

  .ru-card-heading {
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0 0 10px;
    line-height: 41px;
  }

  .ru-card-tagline {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0 0 18px;
    line-height: 1.4;
  }

  .ru-card-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ru-card-item {
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--zg-dark);
    line-height: 41px;
    margin: 0;
  }

  /* Bottom tagline: 24px/500, --zg-muted */
  .ru-tagline {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--zg-muted);
    margin: 0;
    line-height: 41px;
  }

  /* ── Mobile ── */
  @media (max-width: 1100px) {
    .ru-container {
      padding: 0 48px;
    }
  }

  @media (max-width: 768px) {
    .ru-main {
      padding: 48px 0 72px;
    }

    .ru-container {
      padding: 0 20px;
    }

    .ru-title {
      font-size: 1.75rem;
      line-height: 1.3;
    }

    .ru-subtitle {
      font-size: 1rem;
      line-height: 1.5;
      margin-bottom: 32px;
    }

    .ru-columns {
      grid-template-columns: 1fr;
      gap: 40px;
      margin-bottom: 32px;
    }

    .ru-section-heading,
    .ru-card-heading {
      font-size: 1.25rem;
      line-height: 1.3;
    }

    .ru-section-heading-wrap {
      margin-bottom: 10px;
    }

    .ru-heading-icon {
      width: 36px;
    }

    .ru-heading-icon svg {
      max-width: 32px;
      max-height: 32px;
    }

    .ru-item,
    .ru-card-item {
      font-size: 1rem;
      line-height: 1.65;
    }

    .ru-card-tagline {
      font-size: 1.125rem;
    }

    .ru-right {
      padding: 24px;
    }

    .ru-tagline {
      font-size: 1rem;
      line-height: 1.6;
    }
  }
</style>
