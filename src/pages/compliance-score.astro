---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { COMPLIANCE_QUESTIONS, SECTION_LABELS } from '../lib/compliance/questions';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Compliance Score — Zengarden"
      description="School compliance checker mapped to SC Guidelines and CBSE requirements."
    />
  </head>
  <body class="cc-page">
    <Header />

    <main class="cc-main">
      <section class="cc-section">
        <div class="container">
          <div id="compliance-app" class="cc-app">
          <section class="cc-card cc-entry">
            <h1 class="cc-title">Is your school compliant with India's new mental health mandates?</h1>
            <p class="cc-subtitle">Answer a short set of questions about your current systems, staff, and processes. We'll map your answers against the Supreme Court's binding guidelines and CBSE's 2026 affiliation rules — and show you exactly where your school has gaps, which regulations you're exposed on, and how to fix each one.</p>
            <button class="cc-btn cc-btn--primary" data-action="start" type="button">Start the check →</button>
            <p class="cc-micro">Confidential · No sign-up required · Free · Results in 3 minutes</p>
            <div class="cc-bottom-strip">Based on: SC Guidelines (July 25, 2025) · CBSE Affiliation Bye-Laws (January 2026) · CBSE Circular TRG-03/2026 (February 2026)</div>
          </section>
          </div>

          <section class="cc-report-includes" id="cc-report-includes">
            <h2 class="cc-report-heading">What your compliance report includes</h2>
            <div class="cc-report-grid">
              <article class="cc-report-item">
                <div class="cc-report-icon" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M6 4h12v16H6z" stroke="currentColor" stroke-width="1.8"/><path d="M9 9h6M9 13h6M9 17h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </div>
                <h3>Your overall compliance score</h3>
                <p>A percentage score and compliance band — Compliant, Partially Compliant, or Non-Compliant — mapped against the SC guidelines and CBSE affiliation rules that apply to your school.</p>
              </article>
              <article class="cc-report-item">
                <div class="cc-report-icon" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 9v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M12 17h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" stroke="currentColor" stroke-width="1.8"/></svg>
                </div>
                <h3>Your specific gaps</h3>
                <p>Every area where your school is currently exposed — mapped to the exact SC guideline or CBSE rule you're missing, with the legal risk called out clearly.</p>
              </article>
              <article class="cc-report-item">
                <div class="cc-report-icon" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M4 18h6l2-4h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="m15 7 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <h3>How to fix each gap</h3>
                <p>For every gap identified, we show you what closing it looks like in practice — so you leave with a clear next step, not just a score.</p>
              </article>
            </div>
          </section>
        </div>
      </section>
    </main>

    <script type="module" define:vars={{ questionBank: COMPLIANCE_QUESTIONS, sectionLabels: SECTION_LABELS, devMode: import.meta.env.DEV }}>
      const app = document.getElementById('compliance-app');

      const answerOptions = [
        { value: 'no', label: 'No', sub: 'Not in place', score: '1' },
        { value: 'partially', label: 'Partially', sub: 'In progress', score: '2' },
        { value: 'yes', label: 'Yes', sub: 'Fully in place', score: '3' },
      ];

      const state = {
        screen: 'entry',
        isCBSE: null,
        questionIndex: 0,
        autoAdvancing: false,
        previewMode: false,
        answers: {},
        form: {
          contactName: '',
          schoolName: '',
          email: '',
          phone: '',
        },
        loadingProgress: 0,
        loadingLine: 1,
        loadingTimer: null,
        result: null,
        submissionId: '',
        submitError: '',
        submitting: false,
      };

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/\"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function getVisibleQuestions() {
        if (state.isCBSE === null) return [];
        return questionBank.filter((q) => state.isCBSE || !q.cbseOnly);
      }

      function getBand(score) {
        if (score >= 85) return 'green';
        if (score >= 60) return 'amber';
        return 'red';
      }

      function getSectionStatus(score) {
        if (score >= 75) return 'green';
        if (score >= 50) return 'amber';
        return 'red';
      }

      function buildLocalPreviewResult(payload) {
        const pointsMap = { yes: 2, partially: 1, no: 0 };
        const visibleQuestions = getVisibleQuestions();
        const sectionOrder = ['people', 'systems', 'students', 'records', 'training'];
        const sectionTotals = new Map();
        const gaps = [];
        let totalPoints = 0;

        for (const q of visibleQuestions) {
          const answer = payload.answers[q.id] || 'no';
          const points = pointsMap[answer] ?? 0;
          totalPoints += points;

          const prev = sectionTotals.get(q.section) || { points: 0, maxPoints: 0 };
          sectionTotals.set(q.section, { points: prev.points + points, maxPoints: prev.maxPoints + 2 });

          if (answer !== 'yes') {
            gaps.push({
              questionId: q.id,
              answer,
              points,
              section: q.section,
              shortTitle: q.shortTitle,
              question: q.question,
              regulatoryRef: q.regulatoryRef,
              legalRisk: q.legalRisk,
              zengardenCovers: q.zengardenCovers,
              severityRank: answer === 'no' ? 0 : 1,
            });
          }
        }

        const totalMaxPoints = visibleQuestions.length * 2;
        const overallScore = totalMaxPoints > 0 ? Math.round((totalPoints / totalMaxPoints) * 100) : 0;
        const band = getBand(overallScore);

        const sectionScores = sectionOrder.map((id) => {
          const totals = sectionTotals.get(id) || { points: 0, maxPoints: 0 };
          const score = totals.maxPoints > 0 ? Math.round((totals.points / totals.maxPoints) * 100) : 0;
          return {
            id,
            label: sectionLabels[id] || id,
            score,
            status: getSectionStatus(score),
            points: totals.points,
            maxPoints: totals.maxPoints,
          };
        });

        const questionOrder = new Map(questionBank.map((q) => [q.id, q.order]));
        const regRank = (ref) => {
          const upper = String(ref || '').toUpperCase();
          if (upper.includes('SC')) return 0;
          if (upper.includes('CBSE')) return 1;
          return 2;
        };

        gaps.sort((a, b) => {
          if (a.severityRank !== b.severityRank) return a.severityRank - b.severityRank;
          const rr = regRank(a.regulatoryRef) - regRank(b.regulatoryRef);
          if (rr !== 0) return rr;
          return (questionOrder.get(a.questionId) || 999) - (questionOrder.get(b.questionId) || 999);
        });

        const visibleGaps = gaps.slice(0, 5);
        const hiddenGapCount = Math.max(0, gaps.length - visibleGaps.length);
        const topGaps = gaps.slice(0, 3);

        return {
          schoolName: payload.schoolName,
          isCBSE: payload.isCBSE,
          totalPoints,
          totalMaxPoints,
          overallScore,
          band,
          sectionScores,
          visibleGaps,
          hiddenGapCount,
          topGaps,
          allGaps: gaps,
        };
      }

      function renderEntry() {
        return `
          <section class="cc-card cc-entry">
            <h1 class="cc-title">Is your school compliant with India's new mental health mandates?</h1>
            <p class="cc-subtitle">Answer a short set of questions about your current systems, staff, and processes. We'll map your answers against the Supreme Court's binding guidelines and CBSE's 2026 affiliation rules — and show you exactly where your school has gaps, which regulations you're exposed on, and how to fix each one.</p>
            <button class="cc-btn cc-btn--primary" data-action="start">Start the check →</button>
            <p class="cc-micro">Confidential · No sign-up required · Free · Results in 3 minutes</p>
            <div class="cc-bottom-strip">Based on: SC Guidelines (July 25, 2025) · CBSE Affiliation Bye-Laws (January 2026) · CBSE Circular TRG-03/2026 (February 2026)</div>
          </section>
        `;
      }

      function renderGate() {
        const gateValue = state.isCBSE === null ? '' : state.isCBSE ? 'yes' : 'no';
        const gateNote = gateValue ? 'Answer saved' : 'Choose an answer to continue.';

        return `
          <section class="cc-card cc-question-shell">
            <div class="cc-question-top">
              <div>
                <p class="cc-question-count">Question 1</p>
                <p class="cc-trait">School Profile</p>
              </div>
              <span class="cc-progress-pill">5%</span>
            </div>
            <div class="cc-progress"><div style="width:5%"></div></div>

            <div class="cc-question-stage">
              <h2 class="cc-question-text cc-question-text--center">Is your school affiliated with CBSE?</h2>
              <div class="cc-answer-options">
                <label class="cc-answer-option ${gateValue === 'yes' ? 'is-selected' : ''}">
                <input type="radio" name="cbse_gate" value="yes" ${gateValue === 'yes' ? 'checked' : ''} />
                <div>
                  <strong>Yes</strong>
                </div>
              </label>
              <label class="cc-answer-option ${gateValue === 'no' ? 'is-selected' : ''}">
                <input type="radio" name="cbse_gate" value="no" ${gateValue === 'no' ? 'checked' : ''} />
                <div>
                  <strong>No</strong>
                </div>
              </label>
            </div>
            </div>

            <div class="cc-question-footer">
              <button class="cc-btn cc-btn--ghost" data-action="back-to-entry">Back</button>
              <p class="cc-footer-note">${gateNote}</p>
              <button class="cc-btn cc-btn--primary" data-action="to-sections" ${state.isCBSE === null ? 'disabled' : ''}>Continue →</button>
            </div>
          </section>
        `;
      }

      function renderSection() {
        const questions = getVisibleQuestions();
        const totalQuestions = questions.length;
        const question = questions[state.questionIndex];
        if (!question) {
          state.screen = 'email';
          return renderEmailGate();
        }
        const selected = state.answers[question.id] || '';
        const progress = Math.round(((state.questionIndex + 1) / totalQuestions) * 100);
        const sectionName = sectionLabels[question.section] || 'Compliance';
        const footerNote = state.autoAdvancing
          ? 'Saving answer…'
          : selected
            ? 'Answer saved'
            : 'Choose an answer to continue.';

        return `
          <section class="cc-card cc-question-shell">
            <div class="cc-question-top">
              <div>
                <p class="cc-question-count">Question ${state.questionIndex + 1} of ${totalQuestions}</p>
                <p class="cc-trait">${escapeHtml(sectionName)}</p>
              </div>
              <span class="cc-progress-pill">${progress}%</span>
            </div>
            <div class="cc-progress"><div style="width:${progress}%"></div></div>

            <div class="cc-question-stage">
              <h2 class="cc-question-text cc-question-text--center">${escapeHtml(question.question)}</h2>
              <div class="cc-answer-options">
                ${answerOptions.map((opt) => `
                  <label class="cc-answer-option ${selected === opt.value ? 'is-selected' : ''}">
                    <input type="radio" name="${question.id}" value="${opt.value}" ${selected === opt.value ? 'checked' : ''} />
                    <div>
                      <strong>${opt.label}</strong>
                      <p>${opt.sub}</p>
                    </div>
                  </label>
                `).join('')}
              </div>
            </div>

            <div class="cc-question-footer">
              <button class="cc-btn cc-btn--ghost" data-action="section-back">Back</button>
              <p class="cc-footer-note">${footerNote}</p>
              <button class="cc-btn cc-btn--primary" data-action="section-next" ${selected && !state.autoAdvancing ? '' : 'disabled'}>
                ${state.questionIndex === totalQuestions - 1 ? 'Continue to report details →' : 'Next question →'}
              </button>
            </div>
          </section>
        `;
      }

      function renderEmailGate() {
        return `
          <section class="cc-card">
            <p class="cc-step">Final step before score</p>
            <h2 class="cc-heading">Your compliance report is ready.</h2>
            <p class="cc-subcopy">Enter your details below to see your score, section breakdown, and specific compliance gaps.</p>

            <form id="cc-email-form" class="cc-form">
              <label>
                Your name
                <input name="contactName" required value="${escapeHtml(state.form.contactName)}" />
              </label>
              <label>
                School name
                <input name="schoolName" required value="${escapeHtml(state.form.schoolName)}" />
              </label>
              <label>
                Email address
                <input name="email" type="email" required value="${escapeHtml(state.form.email)}" />
              </label>
              <label>
                Phone number (optional)
                <input name="phone" value="${escapeHtml(state.form.phone)}" placeholder="For a follow-up call from our team" />
              </label>

              ${state.submitError ? `<p class="cc-error">${escapeHtml(state.submitError)}</p>` : ''}

              <button class="cc-btn cc-btn--primary" type="submit" ${state.submitting ? 'disabled' : ''}>
                ${state.submitting ? 'Generating report…' : 'See my compliance score →'}
              </button>
            </form>

            <p class="cc-micro">We will email your full gap report to the address above. We do not share your data with third parties.</p>
            <p class="cc-privacy">Your answers are stored securely and used only to generate your report and relevant follow-up.</p>

            <div class="cc-actions">
              <button class="cc-btn cc-btn--ghost" data-action="email-back">Back</button>
            </div>
          </section>
        `;
      }

      function renderLoading() {
        const secondLine = state.isCBSE
          ? "Mapping against CBSE's 2026 affiliation rules..."
          : 'Mapping your compliance exposure...';

        return `
          <section class="cc-card cc-loading">
            <h2 class="cc-heading">Generating your report</h2>
            <p class="cc-loading-line ${state.loadingLine >= 1 ? 'is-on' : ''}">Checking your answers against 15 SC guidelines...</p>
            <p class="cc-loading-line ${state.loadingLine >= 2 ? 'is-on' : ''}">${secondLine}</p>
            <p class="cc-loading-line ${state.loadingLine >= 3 ? 'is-on' : ''}">Generating your personalised gap report...</p>
            <div class="cc-loading-bar"><span style="width:${state.loadingProgress}%"></span></div>
          </section>
        `;
      }

      function getBandMeta(band) {
        if (band === 'green') {
          return {
            label: 'Compliant',
            description: 'Your school meets most SC and CBSE requirements. Minor gaps remain.',
            bg: '#E1F5EE',
          };
        }
        if (band === 'amber') {
          return {
            label: 'Partially Compliant',
            description: 'Your school has significant gaps and regulatory exposure that require urgent attention.',
            bg: '#FAEEDA',
          };
        }
        return {
          label: 'Non-Compliant — Significant Exposure',
          description: 'Your school is currently non-compliant. Immediate action is required to avoid regulatory action and legal liability.',
          bg: '#FAECE7',
        };
      }

      function renderResult() {
        const result = state.result;
        const bandMeta = getBandMeta(result.band);
        const previewNote = state.previewMode
          ? `<div class="cc-card cc-preview-note"><p>Preview mode: showing locally generated results because backend services are not configured yet.</p></div>`
          : '';

        const devAction = devMode
          ? '<button class="cc-btn cc-btn--ghost cc-dev-btn" data-action="open-dev-report">Dev: Generate Report PDF</button>'
          : '';

        return `
          <section class="cc-result">
            <div class="cc-score-head" style="background:${bandMeta.bg}">
              <p class="cc-score-school">${escapeHtml(result.schoolName)}</p>
              <div class="cc-score-num">${result.overallScore}%</div>
              <h2 class="cc-score-band">${bandMeta.label}</h2>
              <p class="cc-score-band-desc">${bandMeta.description}</p>
            </div>
            ${previewNote}

            <div class="cc-card cc-result-card">
              <h3 class="cc-block-title">Where your school stands — section by section</h3>
              <div class="cc-section-rows">
                ${result.sectionScores.map((s) => {
                  const icon = s.status === 'green' ? '✓' : s.status === 'amber' ? '⚠' : '✗';
                  return `
                    <div class="cc-section-row">
                      <p class="cc-section-label">${escapeHtml(s.label)}</p>
                      <div class="cc-section-bar"><span class="is-${s.status}" style="width:${s.score}%"></span></div>
                      <p class="cc-section-score">${s.score}% ${icon}</p>
                    </div>
                  `;
                }).join('')}
              </div>
            </div>

            <div class="cc-card cc-result-card">
              <h3 class="cc-block-title">Your compliance gaps</h3>
              <p class="cc-subcopy">These are the specific areas where your school is currently exposed.</p>
              <div class="cc-gap-list">
                ${result.visibleGaps.map((gap) => `
                  <article class="cc-gap-card ${gap.answer === 'no' ? 'is-no' : 'is-partial'}">
                    <h4>${escapeHtml(gap.shortTitle)}</h4>
                    <p class="cc-gap-ref">${escapeHtml(gap.regulatoryRef)}</p>
                    <p>${escapeHtml(gap.legalRisk)}</p>
                    <a href="#close-gaps-cta">Zengarden covers this →</a>
                  </article>
                `).join('')}
              </div>
              ${result.hiddenGapCount > 0 ? `<p class="cc-gap-more">+ ${result.hiddenGapCount} more gaps identified — reviewed in your demo</p>` : ''}
            </div>

            <div class="cc-card cc-result-card" id="close-gaps-cta">
              <p class="cc-step">The fastest way to close these gaps</p>
              <h3 class="cc-block-title">Book a 20-minute demo</h3>
              <p class="cc-subcopy">We'll walk through your specific gaps, show you exactly how Zengarden covers each one, and give you a custom quote for your school size.</p>
              <a class="cc-btn cc-btn--primary" href="https://calendly.com/aaddii091" target="_blank" rel="noopener noreferrer">Book a Demo →</a>
              ${devAction}
            </div>

            <div class="cc-card cc-urgency-note">
              <div class="cc-note-head">
                <span class="cc-note-icon" aria-hidden="true">!</span>
                <div>
                  <p class="cc-note-kicker">Important Note</p>
                  <h3>A note on timing</h3>
                </div>
              </div>
              <ul class="cc-note-list">
                <li>The Supreme Court guidelines have been in force since July 25, 2025.</li>
                <li>CBSE's counsellor mandate is effective from January 2026.</li>
                <li>District magistrate compliance inspections are already underway in several states.</li>
                <li>Every week without a compliant system is a week of legal exposure for your institution and its management.</li>
              </ul>
            </div>
          </section>
        `;
      }

      function render() {
        if (!app) return;
        const reportIncludes = document.getElementById('cc-report-includes');
        if (reportIncludes) {
          reportIncludes.hidden = state.screen !== 'entry';
        }

        if (state.screen === 'entry') app.innerHTML = renderEntry();
        if (state.screen === 'gate') app.innerHTML = renderGate();
        if (state.screen === 'section') app.innerHTML = renderSection();
        if (state.screen === 'email') app.innerHTML = renderEmailGate();
        if (state.screen === 'loading') app.innerHTML = renderLoading();
        if (state.screen === 'result') app.innerHTML = renderResult();
      }

      function startLoadingAndReveal(resultPayload) {
        state.screen = 'loading';
        state.loadingProgress = 0;
        state.loadingLine = 1;
        render();

        const duration = 2500;
        const start = performance.now();

        if (state.loadingTimer) {
          clearInterval(state.loadingTimer);
          state.loadingTimer = null;
        }

        state.loadingTimer = window.setInterval(() => {
          const elapsed = performance.now() - start;
          const progress = Math.min(100, Math.round((elapsed / duration) * 100));
          state.loadingProgress = progress;
          if (elapsed >= 800) state.loadingLine = 2;
          if (elapsed >= 1600) state.loadingLine = 3;

          const bar = app?.querySelector('.cc-loading-bar span');
          const lines = app?.querySelectorAll('.cc-loading-line');
          if (bar) bar.style.width = `${progress}%`;
          if (lines?.[0]) lines[0].classList.toggle('is-on', state.loadingLine >= 1);
          if (lines?.[1]) lines[1].classList.toggle('is-on', state.loadingLine >= 2);
          if (lines?.[2]) lines[2].classList.toggle('is-on', state.loadingLine >= 3);

          if (elapsed >= duration) {
            clearInterval(state.loadingTimer);
            state.loadingTimer = null;
            state.result = resultPayload;
            state.screen = 'result';
            render();
          }
        }, 80);
      }

      async function submitForm(form) {
        state.submitError = '';
        state.submitting = true;
        render();

        const payload = {
          contactName: form.contactName.trim(),
          schoolName: form.schoolName.trim(),
          email: form.email.trim(),
          phone: form.phone.trim(),
          isCBSE: state.isCBSE,
          answers: state.answers,
        };

        try {
          const res = await fetch('/api/compliance/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Submission failed');

          state.submitting = false;
          state.previewMode = false;
          state.submissionId = data.submissionId;
          startLoadingAndReveal(data);
        } catch (err) {
          state.submitting = false;
          state.previewMode = true;
          state.submissionId = '';
          const fallbackResult = buildLocalPreviewResult(payload);
          startLoadingAndReveal(fallbackResult);
        }
      }

      async function openDevReportInNewTab() {
        try {
          const payload = {
            contactName: state.form.contactName || 'Dev User',
            schoolName: state.form.schoolName || 'Demo School',
            isCBSE: state.isCBSE,
            answers: state.answers,
          };

          const res = await fetch('/api/compliance/dev-report', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!res.ok) throw new Error('Failed to generate dev report');

          const blob = await res.blob();
          const blobUrl = URL.createObjectURL(blob);
          window.open(blobUrl, '_blank', 'noopener,noreferrer');
          window.setTimeout(() => URL.revokeObjectURL(blobUrl), 30000);
        } catch (error) {
          console.error(error);
        }
      }

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        const actionEl = target.closest('[data-action]');
        if (!actionEl) return;

        const action = actionEl.getAttribute('data-action');

        if (action === 'start') {
          state.screen = 'gate';
          render();
        }

        if (action === 'back-to-entry') {
          state.screen = 'entry';
          render();
        }

        if (action === 'to-sections' && state.isCBSE !== null) {
          state.screen = 'section';
          state.questionIndex = 0;
          render();
        }

        if (action === 'section-back') {
          if (state.questionIndex === 0) {
            state.screen = 'gate';
          } else {
            state.questionIndex -= 1;
          }
          render();
        }

        if (action === 'section-next') {
          if (state.autoAdvancing) return;
          const questions = getVisibleQuestions();
          const current = questions[state.questionIndex];
          if (!current || !state.answers[current.id]) {
            return;
          }
          if (state.questionIndex === questions.length - 1) {
            state.screen = 'email';
          } else {
            state.questionIndex += 1;
          }
          render();
        }

        if (action === 'email-back') {
          state.screen = 'section';
          state.questionIndex = Math.max(0, getVisibleQuestions().length - 1);
          render();
        }

        if (action === 'open-dev-report') {
          void openDevReportInNewTab();
        }
      });

      document.addEventListener('change', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;

        if (target.name === 'cbse_gate') {
          if (target.value === 'yes') {
            state.isCBSE = true;
          }
          if (target.value === 'no') {
            state.isCBSE = false;
          }

          const hiddenIds = questionBank.filter((q) => q.cbseOnly).map((q) => q.id);
          if (!state.isCBSE) {
            for (const id of hiddenIds) delete state.answers[id];
          }

          render();
          return;
        }

        const q = questionBank.find((item) => item.id === target.name);
        if (q && ['yes', 'partially', 'no'].includes(target.value)) {
          state.answers[target.name] = target.value;
          if (state.screen === 'section') {
            const questions = getVisibleQuestions();
            const current = questions[state.questionIndex];
            if (current && current.id === target.name && !state.autoAdvancing) {
              state.autoAdvancing = true;
              const shell = app?.querySelector('.cc-question-shell');
              const footerNote = app?.querySelector('.cc-footer-note');
              if (shell) shell.classList.add('is-advancing');
              if (footerNote) footerNote.textContent = 'Saving answer…';

              window.setTimeout(() => {
                state.autoAdvancing = false;
                if (state.questionIndex === questions.length - 1) {
                  state.screen = 'email';
                } else {
                  state.questionIndex += 1;
                }
                render();
              }, 240);
              return;
            }
          }
          render();
        }
      });

      document.addEventListener('submit', (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) return;
        if (form.id !== 'cc-email-form') return;

        event.preventDefault();

        const formData = new FormData(form);
        const values = {
          contactName: String(formData.get('contactName') || ''),
          schoolName: String(formData.get('schoolName') || ''),
          email: String(formData.get('email') || ''),
          phone: String(formData.get('phone') || ''),
        };

        state.form = values;

        if (!values.contactName.trim() || !values.schoolName.trim() || !values.email.trim()) {
          state.submitError = 'Please complete all required fields.';
          render();
          return;
        }

        void submitForm(values);
      });

    </script>

    <Footer />
  </body>
</html>

