<script>
  /* ── Snake flow: sequential step-by-step glow on scroll ── */
  const section = document.querySelector<HTMLElement>('.checkin-section');
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.flow-grid .cflow-card'));
  let rafId: number | undefined;

  // Sort cards into sequential order 01→06 using data-step
  const sortedCards = [1, 2, 3, 4, 5, 6]
    .map(n => allCards.find(c =>
      c.querySelector<HTMLElement>('[data-step]')?.dataset.step === String(n).padStart(2, '0')
    ))
    .filter((c): c is HTMLElement => !!c);

  const clearActive = () => allCards.forEach(c => c.classList.remove('is-active'));

  const updateHighlight = () => {
    if (!section || !sortedCards.length) return;
    const rect = section.getBoundingClientRect();
    // Progress: 0 when section top hits viewport centre, 1 when section bottom hits viewport centre
    const progress = Math.max(0, Math.min(1,
      (window.innerHeight * 0.5 - rect.top) / rect.height
    ));
    clearActive();
    const idx = Math.min(Math.floor(progress * sortedCards.length), sortedCards.length - 1);
    sortedCards[idx].classList.add('is-active');
  };

  const onScroll = () => {
    if (rafId !== undefined) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(updateHighlight);
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  updateHighlight();

  /* ── Tab switcher (generic) ── */
  function initTabs(tabsSelector: string, activeTabClass: string, activePanelClass: string) {
    const tabs = document.querySelectorAll<HTMLButtonElement>(tabsSelector);
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('aria-controls');
        if (!targetId) return;
        tabs.forEach((t) => {
          t.classList.remove(activeTabClass);
          t.setAttribute('aria-selected', 'false');
          const panelId = t.getAttribute('aria-controls');
          if (panelId) {
            const panel = document.getElementById(panelId);
            if (panel) { panel.hidden = true; panel.classList.remove(activePanelClass); }
          }
        });
        tab.classList.add(activeTabClass);
        tab.setAttribute('aria-selected', 'true');
        const target = document.getElementById(targetId);
        if (target) { target.hidden = false; target.classList.add(activePanelClass); }
      });
    });
  }

  initTabs('[role="tab"][aria-controls^="tab-"]', 'segment-tab--active', 'segment-panel--active');
  initTabs('[role="tab"][aria-controls^="journey-"]', 'journey-tab--active', 'journey-panel--active');
  initTabs('[role="tab"][aria-controls^="feat-"]', 'features-tab--active', 'features-panel--active');
</script>
