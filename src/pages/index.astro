  .compliance-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--zg-border-light);
    border-radius: 16px;
    overflow: hidden;
  }

  .compliance-col {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    background: white;
  }

  .compliance-col + .compliance-col {
    border-left: 1px solid var(--zg-border-light);
  }

  .compliance-col--featured {
    background: var(--zg-light-bg);
    position: relative;
  }

  .compliance-col-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .compliance-badge {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    flex-shrink: 0;
    color: white;
  }

  .compliance-badge--blue { background: var(--zg-blue); }
  .compliance-badge--teal { background: var(--zg-teal); }

  .compliance-col-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0;
  }

  .compliance-col-sub {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--zg-muted);
    margin: 0;
  }

  .compliance-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .compliance-list li {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--zg-dark);
    padding-left: 22px;
    position: relative;
    line-height: 1.4;
  }

  .compliance-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--zg-teal);
    font-weight: 700;
  }

  .compliance-col-tag {
    display: inline-flex;
    align-self: flex-start;
    background: var(--zg-teal);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: var(--zg-radius-full);
  }

  /* ════════════════════════════════════════════
     SECTION 04 — SEGMENT SWITCHER
  ════════════════════════════════════════════ */
  .segment-section {
    padding: 80px 0;
    background: var(--zg-light-bg);
  }

  .segment-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 36px;
    background: white;
    border: 1px solid var(--zg-border-light);
    border-radius: var(--zg-radius-full);
    padding: 5px;
    width: fit-content;
  }

  .segment-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    border-radius: var(--zg-radius-full);
    border: none;
    background: transparent;
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--zg-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .segment-tab--active,
  .segment-tab:hover {
    background: var(--zg-blue);
    color: white;
  }

  .segment-panel {
    display: none;
  }

  .segment-panel--active {
    display: block;
  }

  .segment-content {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
    align-items: start;
    background: white;
    border-radius: 16px;
    padding: 48px 40px;
  }

  .segment-heading {
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0 0 14px;
  }

  .segment-desc {
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--zg-dark);
    line-height: 1.65;
    margin: 0 0 20px;
  }

  .segment-features {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .segment-features li {
    font-size: 1rem;
    font-weight: 500;
    color: var(--zg-dark);
    padding-left: 22px;
    position: relative;
  }

  .segment-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--zg-teal);
    font-weight: 700;
  }

  .segment-stat-card {
    background: var(--zg-light-bg);
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .seg-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .seg-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--zg-blue);
  }

  .seg-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--zg-muted);
  }

  /* ════════════════════════════════════════════
     SECTION 05 — JOURNEY
  ════════════════════════════════════════════ */
  .checkin-section {
    padding: 80px 0;
    background: white;
  }

  .journey-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 36px;
    border-bottom: 2px solid var(--zg-border-light);
  }

  .journey-tab {
    padding: 10px 24px 12px;
    border: none;
    background: transparent;
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--zg-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
  }

  .journey-tab--active {
    color: var(--zg-blue);
    border-bottom-color: var(--zg-blue);
  }

  .journey-panel {
    display: none;
  }

  .journey-panel--active {
    display: block;
  }

  /* Snake flow grid: 3 cols [card][arrow][card], 5 rows */
  .flow-grid {
    display: grid;
    grid-template-columns: 1fr 72px 1fr;
    grid-template-rows: 1fr auto 1fr auto 1fr;
    align-items: center;
  }

  .flow-harrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    flex-shrink: 0;
    color: var(--zg-blue);
    margin: 0 auto;
  }

  .flow-varrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    color: var(--zg-blue);
    margin: 12px auto;
  }

  .flow-gap-cell {
    min-height: 44px;
  }

  .cflow-card {
    align-self: stretch;
    width: 100%;
  }

  .cflow-card-inner {
    position: relative;
    background: white;
    border-radius: 10px;
    padding: 20px 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    height: 100%;
    box-sizing: border-box;
    border: 1.5px solid var(--zg-input-border);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .cflow-icon {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .cflow-step-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--zg-muted);
    line-height: 1;
    margin-bottom: 2px;
    transition: color 0.3s ease;
  }

  .cflow-card.is-active .cflow-card-inner {
    border-color: var(--zg-blue);
    box-shadow: 0 0 0 3px rgba(60, 80, 224, 0.10), 0 8px 24px rgba(60, 80, 224, 0.14);
    transform: translateY(-2px);
  }

  .cflow-card.is-active .cflow-step-num {
    color: var(--zg-blue);
  }

  .cflow-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0;
  }

  .cflow-desc {
    font-size: 0.875rem;
    color: var(--zg-dark);
    margin: 0;
    line-height: 1.5;
  }

  .icon-teal {
    filter: brightness(0) invert(63%) sepia(87%) saturate(456%) hue-rotate(119deg) brightness(72%) contrast(102%);
  }

  /* Student journey — two rows of 3 */
  .student-journey-wrap {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .student-journey-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 16px;
    align-items: start;
  }

  /* Institution journey */
  .inst-journey-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    gap: 16px;
    align-items: start;
    padding: 8px 0;
  }

  .inst-step {
    background: white;
    border: 1px solid var(--zg-border-light);
    border-radius: 12px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .inst-step-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--zg-blue);
    opacity: 0.35;
    line-height: 1;
  }

  .inst-step-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0;
  }

  .inst-step-desc {
    font-size: 0.9375rem;
    color: var(--zg-dark);
    margin: 0;
    line-height: 1.55;
  }

  .inst-arrow {
    font-size: 1.5rem;
    color: var(--zg-blue);
    align-self: center;
    padding-top: 8px;
    flex-shrink: 0;
  }

  /* ════════════════════════════════════════════
     SECTION 06 — PLATFORM FEATURES
  ════════════════════════════════════════════ */
  .features-section {
    padding: 80px 0;
    background: var(--zg-light-bg);
  }

  .features-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 32px;
    background: white;
    border: 1px solid var(--zg-border-light);
    border-radius: var(--zg-radius-full);
    padding: 5px;
    width: fit-content;
  }

  .features-tab {
    padding: 9px 22px;
    border: none;
    border-radius: var(--zg-radius-full);
    background: transparent;
    font-family: 'Nunito', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--zg-muted);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .features-tab--active {
    background: var(--zg-blue);
    color: white;
  }

  .features-tab:hover:not(.features-tab--active) {
    background: var(--zg-hover-light);
    color: var(--zg-blue);
  }

  .features-panel {
    display: none;
  }

  .features-panel--active {
    display: block;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .feat-card {
    background: white;
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .feat-icon {
    width: 52px;
    height: 52px;
    line-height: 1;
  }

  .feat-icon img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .feat-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0;
  }

  .feat-desc {
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--zg-dark);
    margin: 0;
    line-height: 1.55;
  }

  /* ════════════════════════════════════════════
     SECTION 07 — PRINCIPLES
  ════════════════════════════════════════════ */
  .principles-section {
    padding: 80px 0;
    background: white;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .principle-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0 32px;
  }

  .principle-card:first-child {
    padding-left: 0;
  }

  .principle-card:last-child {
    padding-right: 0;
  }

  .principle-card + .principle-card {
    border-left: 2px solid var(--zg-blue-25);
  }

  .principle-num {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--zg-blue);
    opacity: 0.3;
    line-height: 1;
  }

  .principle-title {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 600;
    color: var(--zg-mid);
    margin: 0;
  }

  .principle-desc {
    font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    font-weight: 400;
    color: var(--zg-dark);
    margin: 0;
    line-height: 1.6;
  }

  /* ════════════════════════════════════════════
     SECTION 08 — COST COMPARISON
  ════════════════════════════════════════════ */
  .cost-section {
    padding: 80px 0;
    background: var(--zg-light-bg);
  }

  .cost-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .cost-card {
    padding: 40px 36px;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cost-card--alt {
    background: white;
    border: 1px solid var(--zg-border-light);
  }

  .cost-card--featured {
    background: var(--zg-blue);
    color: white;
  }

  .cost-card-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: inherit;
    margin: 0;
  }

  .cost-card--alt .cost-card-title {
    color: var(--zg-mid);
  }

  .cost-amount {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--zg-mid);
    line-height: 1;
  }

  .cost-card--featured .cost-amount {
    color: white;
  }

  .cost-amount--teal {
    color: var(--zg-teal) !important;
  }

  .cost-amount-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--zg-muted);
    margin: 0;
  }

  .cost-card--featured .cost-amount-label {
    color: rgba(255,255,255,0.7);
  }

  .cost-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .cost-list li {
    font-size: 0.9375rem;
    font-weight: 500;
    padding-left: 22px;
    position: relative;
    line-height: 1.4;
  }

  .cost-list--cons li { color: var(--zg-muted); }
  .cost-list--pros li { color: rgba(255,255,255,0.9); }

  .cost-list--cons li::before {
    content: "–";
    position: absolute;
    left: 0;
    color: #9ca3af;
  }

  .cost-list--pros li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--zg-teal);
    font-weight: 700;
  }

  .cost-vs {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--zg-muted);
    padding: 0 24px;
    text-align: center;
  }

  .cost-cta {
    margin-top: 8px;
    align-self: flex-start;
  }

  .cost-note {
    text-align: center;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--zg-muted);
    margin: 32px auto 0;
    max-width: 640px;
  }

  /* ════════════════════════════════════════════
     SECTION 09 — SOCIAL PROOF
  ════════════════════════════════════════════ */
  .proof-section {
    padding: 80px 0;
    background: white;
  }

  .proof-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 48px;
    text-align: center;
  }

  .proof-stat-num {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--zg-blue);
    line-height: 1;
    margin-bottom: 6px;
  }

  .proof-stat-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--zg-muted);
    line-height: 1.4;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testimonial-card {
    background: var(--zg-light-bg);
    border-radius: 16px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .testimonial-text {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--zg-dark);
    line-height: 1.65;
    margin: 0;
    flex: 1;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--zg-blue);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .testimonial-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0;
  }

  .testimonial-school {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--zg-muted);
    margin: 0;
  }

  /* ════════════════════════════════════════════
     SECTION 10 — FAQ
  ════════════════════════════════════════════ */
  .faq-section {
    padding: 80px 0;
    background: var(--zg-light-bg);
  }

  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    background: white;
    border: 1px solid var(--zg-border-light);
    border-radius: 0;
    overflow: hidden;
  }

  .faq-item:first-child { border-radius: 12px 12px 0 0; }
  .faq-item:last-child { border-radius: 0 0 12px 12px; }
  .faq-item + .faq-item { border-top: none; }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--zg-mid);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question:hover {
    background: var(--zg-hover-light);
  }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--zg-muted);
    transition: transform 0.2s;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 24px 20px;
    border-top: 1px solid var(--zg-border-light);
  }

  .faq-answer p {
    font-size: 1rem;
    font-weight: 400;
    color: var(--zg-dark);
    line-height: 1.65;
    margin: 16px 0 0;
  }

  /* ════════════════════════════════════════════
     SECTION 11 — FINAL CTA
  ════════════════════════════════════════════ */
  .final-cta-section {
    padding: 80px 0;
    background: white;
  }

  .final-cta-inner {
    background: linear-gradient(135deg, var(--zg-blue) 0%, #2a3abf 100%);
    border-radius: 24px;
    padding: 72px 64px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .final-cta-badge {
    display: inline-flex;
    padding: 5px 16px;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: var(--zg-radius-full);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .final-cta-heading {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: white;
    margin: 0;
    line-height: 1.15;
  }

  .final-cta-sub {
    font-size: clamp(1rem, 1.8vw, 1.1875rem);
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    max-width: 560px;
    line-height: 1.6;
    margin: 0;
  }

  .final-cta-sub--emphasis {
    font-weight: 700;
    color: white;
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
  }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 8px;
  }

  .final-cta-whatsapp,
  .final-cta-call {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 24px;
    border-radius: var(--zg-radius-full);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, opacity 0.15s;
  }

  .final-cta-whatsapp {
    background: rgba(255,255,255,0.15);
    color: white;
    border: 1.5px solid rgba(255,255,255,0.35);
  }

  .final-cta-whatsapp:hover {
    background: rgba(255,255,255,0.25);
  }

  .final-cta-call {
    background: transparent;
    color: rgba(255,255,255,0.8);
    border: 1.5px solid rgba(255,255,255,0.25);
  }

  .final-cta-call:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }

  /* ════════════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════════════ */
  @media (max-width: 1100px) {
    .urgency-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .care-grid {
      grid-template-columns: 1fr;
    }

    .compliance-grid {
      grid-template-columns: 1fr;
    }

    .compliance-col + .compliance-col {
      border-left: none;
