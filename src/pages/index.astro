---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const principles = [
  {
    title: 'Right Support',
    desc: 'Every student deserves guidance that fits their needs. The right kind of support, delivered at the right time, makes all the difference.',
  },
  {
    title: 'Responsible Care',
    desc: 'Support should always be timely, structured, confidential, and professionally handled — never left to chance.',
  },
  {
    title: 'Human-led Scale',
    desc: 'Technology should help institutions support more students efficiently, without losing the human touch that makes care meaningful.',
  },
  {
    title: 'Compliant by Design',
    desc: 'Built around SC Guidelines, CBSE mandates, and UGC norms from day one — Zengarden makes compliance a feature, not an afterthought.',
  },
];

const faqs = [
  {
    q: 'How does Zengarden help schools meet SC Guidelines?',
    a: 'Zengarden provides a documented, structured support pathway with licensed psychologists, session records, and audit-ready reports — all aligned with the Supreme Court\'s mandate for institutional mental health infrastructure.',
  },
  {
    q: 'What compliance documentation does the platform generate?',
    a: 'The platform auto-generates annual wellness reports, student check-in records, counsellor activity logs, referral documentation, and session summaries — all formatted for regulatory submission.',
  },
  {
    q: 'Is student data confidential and secure?',
    a: 'Yes. All student data is encrypted at rest and in transit. Counsellors and psychologists see only what is required for care. Institutions see aggregate, anonymised insights — never individual session content.',
  },
  {
    q: 'How is Zengarden different from a generic wellness app?',
    a: 'Zengarden is built specifically for the Indian education regulatory environment. It is the only platform that maps support workflows directly to SC Guidelines, CBSE requirements, and UGC norms — not just general well-being.',
  },
  {
    q: 'What does implementation look like for a school or university?',
    a: 'Most institutions are live within 2–4 weeks. We handle onboarding, counsellor training, student communication, and compliance configuration. Dedicated support is included in every plan.',
  },
  {
    q: 'What does Zengarden cost?',
    a: 'Pricing is based on institution size and is significantly lower than the cost of hiring a full-time counsellor — while covering your entire student body. Contact us or book a demo to get a tailored quote.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>

      <!-- ═══════════════════════════════════════════
           SECTION 01 — HERO
      ═══════════════════════════════════════════ -->
      <section class="hero">
        <div class="container hero-inner">
          <div class="hero-text">
            <div class="hero-pills">
              <span class="hero-pill hero-pill--teal">Real Care for Every Student</span>
              <span class="hero-pill">SC Compliant</span>
              <span class="hero-pill">CBSE Certified</span>
              <span class="hero-pill">UGC Aligned</span>
            </div>
            <h1 class="hero-heading">Real Support for Every Student.<br />Full Compliance for Your Institution.</h1>
            <p class="hero-desc">
              Students get personality-based check-ins, licensed mentors, and certified psychologists. Institutions get documented workflows, audit-ready reports, and complete regulatory coverage — SC Guidelines, CBSE, and UGC, all in one place.
            </p>
            <div class="hero-ctas">
              <Button variant="teal" href="https://calendly.com/aaddii091" size="lg" class="hero-demo-btn" target="_blank" rel="noopener noreferrer">Book a Demo</Button>
              <Button variant="outline" href="/#compliance" size="lg" class="hero-compliance-btn">Check Your Compliance Score</Button>
            </div>
          </div>
          <div class="hero-visual">
            <div class="hero-images">
              <img
                src="/images/hero-mockup.png"
                alt="Zengarden compliance dashboard"
                class="hero-img-laptop"
                width="594"
                height="281"
                loading="eager"
              />
              <img
                src="/images/hero-side.png"
                alt="Zengarden app on mobile"
                class="hero-img-mobile"
                width="160"
                height="326"
                loading="eager"
              />
            </div>
            <div class="hero-ctas hero-demo-mobile-under">
              <Button variant="teal" href="https://calendly.com/aaddii091" size="lg" target="_blank" rel="noopener noreferrer">Book a Demo</Button>
              <Button variant="outline" href="/#compliance" size="lg">Check Compliance Score</Button>
            </div>
          </div>
        </div>

        <!-- Trust bar -->
        <div class="hero-trust-bar">
          <div class="container">
            <div class="trust-bar-inner">
              <span class="trust-stat"><strong>50+</strong> Institutions</span>
              <span class="trust-divider"></span>
              <span class="trust-stat"><strong>12,000+</strong> Students Supported</span>
              <span class="trust-divider"></span>
              <span class="trust-stat"><strong>RCI Certified</strong> Psychologists</span>
              <span class="trust-divider"></span>
              <span class="trust-stat"><strong>Audit-Ready</strong> Reports</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           SECTION 02 — URGENCY STRIP
      ═══════════════════════════════════════════ -->
      <section class="urgency-section">
        <div class="container">
          <p class="urgency-label">The Reality in Indian Schools &amp; Universities</p>
          <div class="urgency-grid">
            <div class="urgency-card urgency-card--outcome">
              <div class="urgency-num urgency-num--teal">87%</div>
              <p class="urgency-desc">of students on Zengarden report feeling heard and supported after their first check-in</p>
              <span class="urgency-source">Zengarden Internal Data</span>
            </div>
            <div class="urgency-card">
              <div class="urgency-num">1 in 4</div>
              <p class="urgency-desc">students experiences academic stress severe enough to require structured support</p>
              <span class="urgency-source">CBSE Wellness Study, 2023</span>
            </div>
            <div class="urgency-card urgency-card--highlight">
              <div class="urgency-num">SC 2022</div>
              <p class="urgency-desc">Supreme Court Guidelines mandate licensed counsellors and documented referral pathways at every educational institution</p>
              <span class="urgency-source">Supreme Court of India</span>
            </div>
            <div class="urgency-card">
              <div class="urgency-num">CBSE</div>
              <p class="urgency-desc">requires affiliated schools to maintain documented mental health programs and periodic student wellness check-ins</p>
              <span class="urgency-source">CBSE Circular 2022-23</span>
            </div>
            <div class="urgency-card urgency-card--legal">
              <div class="urgency-num">⚠</div>
              <p class="urgency-desc">Institutions without compliant mental health infrastructure face regulatory action, affiliation risk, and legal liability</p>
              <span class="urgency-source">Legal note</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           SECTION 03 — COMPLIANCE COVERAGE
      ═══════════════════════════════════════════ -->
      <section class="compliance-section" id="compliance">
        <div class="container">
          <SectionHeader
            heading="One Platform. Full Compliance."
            sub="Zengarden maps every feature to the regulatory framework your institution must meet."
            align="center"
          />
          <div class="compliance-grid">
            <div class="compliance-col">
              <div class="compliance-col-header">
                <div class="compliance-badge compliance-badge--blue">SC</div>
                <div>
                  <h3 class="compliance-col-title">Supreme Court Guidelines</h3>
                  <p class="compliance-col-sub">2022 Mandate</p>
                </div>
              </div>
              <ul class="compliance-list">
                <li>Licensed counsellors available to all students</li>
                <li>Documented student referral pathway</li>
                <li>Confidential session records</li>
                <li>Annual institution wellness audit</li>
                <li>Crisis response protocol</li>
                <li>Parent communication framework</li>
              </ul>
            </div>
            <div class="compliance-col compliance-col--featured">
              <div class="compliance-col-header">
                <div class="compliance-badge compliance-badge--teal">CBSE</div>
                <div>
                  <h3 class="compliance-col-title">CBSE Requirements</h3>
                  <p class="compliance-col-sub">Affiliated Schools</p>
                </div>
              </div>
              <ul class="compliance-list">
                <li>Mandated student wellness programs</li>
                <li>Periodic check-in documentation</li>
                <li>Counsellor availability records</li>
                <li>Structured psychological assessment</li>
                <li>Intervention outcome tracking</li>
                <li>Compliance reporting for affiliation renewal</li>
              </ul>
              <span class="compliance-col-tag">Most schools start here</span>
            </div>
            <div class="compliance-col">
              <div class="compliance-col-header">
                <div class="compliance-badge compliance-badge--blue">UGC</div>
                <div>
                  <h3 class="compliance-col-title">UGC Norms</h3>
                  <p class="compliance-col-sub">Higher Education</p>
                </div>
              </div>
              <ul class="compliance-list">
                <li>Institution mental health policy document</li>
                <li>Student grievance and referral mechanism</li>
                <li>Professional psychological services</li>
                <li>Staff training and awareness program</li>
                <li>Anonymous student feedback system</li>
                <li>Annual compliance reporting to UGC</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           SECTION 3.5 — WHAT STUDENTS ACTUALLY GET
      ═══════════════════════════════════════════ -->
      <section class="care-section">
        <div class="container">
          <SectionHeader
            heading="Complete Support at the Right Level"
            sub="Students move through support based on their actual needs — not a one-size approach."
          />
          <div class="care-grid">
            <div class="care-card">
              <div class="care-card-top">
                <div class="care-icon-wrap care-icon-wrap--blue">
                  <img src="/images/icon-clipboard.png" alt="" width="36" height="36" aria-hidden="true" />
                </div>
                <span class="care-tag">Layer 1</span>
              </div>
              <h3 class="care-title">Self Awareness</h3>
              <p class="care-desc">Students complete personality and well-being questionnaires grounded in globally recognised frameworks — Big Five (OCEAN) and 16PF. Scientifically validated. No preparation needed.</p>
              <p class="care-highlight">Co-developed with licensed psychologists.</p>
            </div>
            <div class="care-card">
              <div class="care-card-top">
                <div class="care-icon-wrap care-icon-wrap--teal">
                  <img src="/images/icon-growth.png" alt="" width="36" height="36" aria-hidden="true" />
                </div>
                <span class="care-tag">Layer 2</span>
              </div>
              <h3 class="care-title">Guidance &amp; Mentorship</h3>
              <p class="care-desc">For students navigating study habits, confidence, career direction, or academic pressure — vetted mentors provide structured, goal-oriented guidance sessions.</p>
              <p class="care-highlight">Ongoing. Not a one-time interaction.</p>
            </div>
            <div class="care-card">
              <div class="care-card-top">
                <div class="care-icon-wrap care-icon-wrap--verified">
                  <img src="/images/icon-star-verified.png" alt="" width="36" height="36" aria-hidden="true" />
                </div>
                <div class="care-badge">MPhil · RCI Certified</div>
              </div>
              <h3 class="care-title">Qualified Psychologists</h3>
              <p class="care-desc">For deeper emotional or psychological needs — students connect with certified professionals in a safe, confidential space. Referrals are structured, not ad hoc.</p>
              <p class="care-highlight">Never left to chance. Never rushed.</p>
            </div>
          </div>
          <div class="care-cta-row">
            <Button variant="outline" href="/responsible-use">See How We Approach Care</Button>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           SECTION 04 — SEGMENT SWITCHER
      ═══════════════════════════════════════════ -->
      <section class="segment-section">
        <div class="container">
          <SectionHeader
            heading="Built for Every Type of Institution"
            sub="Whether you run a CBSE school or a multi-campus university, Zengarden fits your scale and compliance needs."
            align="center"
          />
          <div class="segment-tabs" role="tablist" aria-label="Institution type">
            <button class="segment-tab segment-tab--active" role="tab" aria-selected="true" aria-controls="tab-schools" id="tab-btn-schools" type="button">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 22V12h6v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              For Schools
            </button>
            <button class="segment-tab" role="tab" aria-selected="false" aria-controls="tab-universities" id="tab-btn-universities" type="button">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c3.33 2 8.67 2 12 0v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              For Universities
            </button>
          </div>

          <div id="tab-schools" role="tabpanel" aria-labelledby="tab-btn-schools" class="segment-panel segment-panel--active">
            <div class="segment-content">
              <div class="segment-text">
                <h3 class="segment-heading" id="for-schools">CBSE & ICSE Schools</h3>
                <p class="segment-desc">Designed for school counsellors, principals, and management teams navigating CBSE compliance requirements while caring for students from Grades 6–12.</p>
                <ul class="segment-features">
                  <li>CBSE-compliant wellness check-in for every student</li>
                  <li>Licensed counsellor sessions — on-platform or in-person</li>
                  <li>One-click compliance reports for affiliation renewal</li>
                  <li>Parent communication and consent management</li>
                  <li>Psychologist-reviewed personality assessments</li>
                  <li>Crisis escalation protocol with documented audit trail</li>
                </ul>
                <Button variant="teal" href="https://calendly.com/aaddii091" target="_blank" rel="noopener noreferrer">Book a School Demo</Button>
              </div>
              <div class="segment-visual">
                <div class="segment-stat-card">
                  <div class="seg-stat"><span class="seg-num">4 weeks</span><span class="seg-label">Average time to compliance-ready</span></div>
                  <div class="seg-stat"><span class="seg-num">₹0</span><span class="seg-label">Additional counsellor headcount needed</span></div>
                  <div class="seg-stat"><span class="seg-num">100%</span><span class="seg-label">Student coverage from day one</span></div>
                </div>
              </div>
            </div>
          </div>

          <div id="tab-universities" role="tabpanel" aria-labelledby="tab-btn-universities" class="segment-panel" hidden>
            <div class="segment-content">
              <div class="segment-text">
                <h3 class="segment-heading" id="for-universities">Colleges & Universities</h3>
                <p class="segment-desc">Built for student affairs offices, department heads, and VCs managing mental health at scale across residential campuses and multi-campus environments.</p>
                <ul class="segment-features">
                  <li>UGC-compliant mental health policy framework</li>
                  <li>Department-level student wellness dashboards</li>
                  <li>Residential welfare and hostel integration</li>
                  <li>Multi-psychologist scheduling and session management</li>
                  <li>Anonymous peer-support and feedback mechanisms</li>
                  <li>Annual UGC compliance reporting, auto-generated</li>
                </ul>
                <Button variant="teal" href="https://calendly.com/aaddii091" target="_blank" rel="noopener noreferrer">Book a University Demo</Button>
              </div>
              <div class="segment-visual">
                <div class="segment-stat-card">
                  <div class="seg-stat"><span class="seg-num">Multi-campus</span><span class="seg-label">Single platform, all campuses</span></div>
                  <div class="seg-stat"><span class="seg-num">UGC Ready</span><span class="seg-label">Annual report generated automatically</span></div>
                  <div class="seg-stat"><span class="seg-num">Scalable</span><span class="seg-label">500 to 50,000 students</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           SECTION 05 — JOURNEY (FROM CHECK-IN TO SUPPORT)
      ═══════════════════════════════════════════ -->
      <section class="checkin-section">
        <div class="container">
          <SectionHeader
            heading="From Check-in to Support"
            sub="Designed to reduce delays and help institutions act with clarity, speed, and care."
          />

          <div class="journey-tabs" role="tablist" aria-label="Journey perspective">
            <button class="journey-tab journey-tab--active" role="tab" aria-selected="true" aria-controls="journey-student" id="journey-btn-student" type="button">Student Journey</button>
            <button class="journey-tab" role="tab" aria-selected="false" aria-controls="journey-institution" id="journey-btn-institution" type="button">Institution View</button>
          </div>

          <div id="journey-student" role="tabpanel" aria-labelledby="journey-btn-student" class="journey-panel journey-panel--active">
            <div class="flow-grid">
              <!-- Row 1 -->
              <div class="cflow-card step-checkin">
                <div class="cflow-card-inner" data-step="01">
                  <img src="/images/icon-form.png" alt="" width="32" height="32" aria-hidden="true" class="cflow-icon" />
                  <span class="cflow-step-num">01</span>
                  <h3 class="cflow-title">Student Check-in</h3>
                  <p class="cflow-desc">Personality &amp; well-being questionnaire — no prep needed.</p>
                </div>
              </div>
              <div class="flow-harrow">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="cflow-card step-insights">
                <div class="cflow-card-inner" data-step="02">
                  <img src="/images/icon-verified.png" alt="" width="32" height="32" aria-hidden="true" class="cflow-icon" />
                  <span class="cflow-step-num">02</span>
                  <h3 class="cflow-title">Instant Insights</h3>
                  <p class="cflow-desc">Personalised results built on Big Five &amp; 16PF frameworks.</p>
                </div>
              </div>

              <div class="flow-gap-cell"></div>
              <div class="flow-gap-cell"></div>
              <div class="flow-varrow">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>

              <!-- Row 2 (snake: right → left) -->
              <div class="cflow-card step-guided">
                <div class="cflow-card-inner" data-step="04">
                  <img src="/images/icon-compass.png" alt="" width="32" height="32" aria-hidden="true" class="cflow-icon" />
                  <span class="cflow-step-num">04</span>
                  <h3 class="cflow-title">Guided Direction</h3>
                  <p class="cflow-desc">Recommended next step — mentor, counsellor, or psychologist.</p>
                </div>
              </div>
              <div class="flow-harrow flow-harrow-left">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 12H5M11 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="cflow-card step-review">
                <div class="cflow-card-inner" data-step="03">
                  <img src="/images/icon-star-verified.png" alt="" width="32" height="32" aria-hidden="true" class="cflow-icon" />
                  <span class="cflow-step-num">03</span>
                  <h3 class="cflow-title">Professional Review</h3>
                  <p class="cflow-desc">Results interpreted by psychologist-defined algorithms.</p>
                </div>
              </div>

              <div class="flow-varrow">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="flow-gap-cell"></div>
              <div class="flow-gap-cell"></div>

              <!-- Row 3 -->
              <div class="cflow-card step-choice">
                <div class="cflow-card-inner" data-step="05">
                  <img src="/images/icon-choices.png" alt="" width="32" height="32" aria-hidden="true" class="cflow-icon icon-teal" />
                  <span class="cflow-step-num">05</span>
                  <h3 class="cflow-title">Student's Choice</h3>
                  <p class="cflow-desc">Pick a mentor or certified psychologist, on their own terms.</p>
                </div>
              </div>
              <div class="flow-harrow">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="cflow-card step-sessions">
                <div class="cflow-card-inner" data-step="06">
                  <img src="/images/icon-calendar.png" alt="" width="32" height="32" aria-hidden="true" class="cflow-icon icon-teal" />
                  <span class="cflow-step-num">06</span>
                  <h3 class="cflow-title">Sessions</h3>
                  <p class="cflow-desc">Book, attend, and track. Ongoing — not a one-time interaction.</p>
                </div>
              </div>
            </div>
          </div>

          <div id="journey-institution" role="tabpanel" aria-labelledby="journey-btn-institution" class="journey-panel" hidden>
            <div class="inst-journey-grid">
              <div class="inst-step">
                <div class="inst-step-num">01</div>
                <div class="inst-step-body">
                  <h3 class="inst-step-title">Dashboard Overview</h3>
                  <p class="inst-step-desc">The institution sees aggregate well-being trends across the full student body — no individual data, full picture.</p>
                </div>
              </div>
              <div class="inst-arrow">→</div>
              <div class="inst-step">
                <div class="inst-step-num">02</div>
                <div class="inst-step-body">
                  <h3 class="inst-step-title">Risk Flags &amp; Alerts</h3>
                  <p class="inst-step-desc">When check-in responses indicate concern, counsellors are automatically notified to follow up — within the platform.</p>
                </div>
              </div>
              <div class="inst-arrow">→</div>
              <div class="inst-step">
                <div class="inst-step-num">03</div>
                <div class="inst-step-body">
                  <h3 class="inst-step-title">Counsellor Actions</h3>
                  <p class="inst-step-desc">Counsellors review psychologist-assessed reports, schedule sessions, and log all interventions — documented automatically.</p>
                </div>
              </div>
              <div class="inst-arrow">→</div>
              <div class="inst-step">
                <div class="inst-step-num">04</div>
                <div class="inst-step-body">
                  <h3 class="inst-step-title">Compliance Report</h3>
                  <p class="inst-step-desc">At any time, generate a full regulatory compliance report covering check-ins, sessions, outcomes, and counsellor activity.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           SECTION 06 — PLATFORM FEATURES
      ═══════════════════════════════════════════ -->
      <section class="features-section">
        <div class="container">
          <SectionHeader
            heading="One Platform, Every Stakeholder"
            sub="Purpose-built tools for students, counsellors, psychologists, and institution leadership."
            align="center"
          />
          <div class="features-tabs" role="tablist" aria-label="Platform features by role">
            <button class="features-tab features-tab--active" role="tab" aria-selected="true" aria-controls="feat-students" id="feat-btn-students" type="button">Students</button>
            <button class="features-tab" role="tab" aria-selected="false" aria-controls="feat-counsellors" id="feat-btn-counsellors" type="button">Counsellors</button>
            <button class="features-tab" role="tab" aria-selected="false" aria-controls="feat-institutions" id="feat-btn-institutions" type="button">Institutions</button>
            <button class="features-tab" role="tab" aria-selected="false" aria-controls="feat-psychologists" id="feat-btn-psychologists" type="button">Psychologists</button>
          </div>

          <div id="feat-students" role="tabpanel" aria-labelledby="feat-btn-students" class="features-panel features-panel--active">
            <div class="features-grid">
              <div class="feat-card">
