---
interface Props {
  heading: string;
  sub?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { heading, sub, align = 'left', class: className } = Astro.props;
---

<div class:list={['section-header', align === 'center' && 'section-header--center', className]}>
  <h2 class="section-heading">{heading}</h2>
  {sub && <p class="section-sub">{sub}</p>}
</div>

<style>
  .section-header {
    margin-bottom: 48px;
  }

  .section-header--center {
    text-align: center;
  }

  .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--zg-mid);
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .section-sub {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 400;
    color: var(--zg-mid);
    margin: 0;
  }
</style>
