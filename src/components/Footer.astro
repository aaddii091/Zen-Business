---
import Button from './Button.astro';
const today = new Date();
---

<footer class="zg-footer">
  <div class="zg-footer-bg"></div>
  <div class="zg-footer-inner">
    <div class="zg-footer-main">

      <!-- Left: brand -->
      <div class="zg-footer-brand">
        <div class="zg-footer-logo-wrap">
          <img src="/images/zengarden-logo.png" alt="Zengarden" class="zg-footer-logo" />
          <p class="zg-footer-hq">your emotional headquarters</p>
        </div>
        <p class="zg-footer-tagline">Structured, responsible and confidential student support.</p>
      </div>

      <div class="zg-footer-divider"></div>

      <!-- Right: actions + contact -->
      <div class="zg-footer-actions">
        <Button
          href="https://calendly.com/aaddii091"
          size="sm"
          class="zg-footer-cta"
          target="_blank"
          rel="noopener noreferrer"
        >Book a Demo</Button>

        <div class="zg-footer-contact">
          <a href="mailto:admin@zengarden.co.in" class="zg-footer-contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="29" height="29" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
            admin@zengarden.co.in
          </a>
          <a href="tel:+917727052026" class="zg-footer-contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="29" height="29" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.62 10.79z"/></svg>
            +91 7727052026
          </a>
        </div>

        <div class="zg-footer-links">
          <a href="/responsible-use" class="zg-footer-link">Responsible Use</a>
          <a href="/privacy-policy" class="zg-footer-link">Privacy Policy</a>
        </div>
      </div>

    </div>

    <p class="zg-footer-copy">&copy; {today.getFullYear()} Zengarden. All rights reserved.</p>
  </div>
</footer>

<style>
  .zg-footer {
    position: relative;
    overflow: hidden;
  }

  .zg-footer-bg {
    position: absolute;
    inset: 0;
    background-color: rgba(60, 80, 224, 0.10);
    z-index: 0;
  }

  .zg-footer-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 38px 26px 24px;
  }

  .zg-footer-main {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    margin-bottom: 32px;
  }

  /* --- Left brand column --- */
  .zg-footer-brand {
    flex: 2;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .zg-footer-logo-wrap {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .zg-footer-logo {
    height: 50px;
    width: auto;
    object-fit: contain;
    object-position: left center;
  }

  .zg-footer-hq {
    font-size: 1rem;
    font-weight: 700;
    color: var(--zg-muted);
    margin: 0;
  }

  .zg-footer-tagline {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--zg-mid);
    margin: 0;
    max-width: 364px;
  }

  /* --- Divider --- */
  .zg-footer-divider {
    width: 1px;
    align-self: stretch;
    background: #d0d5e8;
    flex-shrink: 0;
  }

  /* --- Right actions column --- */
  .zg-footer-actions {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  /* Button component override — layout only */
  .zg-footer-cta {
    align-self: flex-start;
    margin-bottom: 26px;
  }

  .zg-footer-contact {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-bottom: 16px;
  }

  .zg-footer-contact-item {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--zg-dark);
    text-decoration: none;
    transition: color 0.15s;
  }

  .zg-footer-contact-item:hover {
    color: var(--zg-blue);
  }

  .zg-footer-contact-item svg {
    flex-shrink: 0;
    color: var(--zg-dark);
  }

  .zg-footer-links {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .zg-footer-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--zg-dark);
    text-decoration: none;
    transition: color 0.15s;
  }

  .zg-footer-link:hover {
    color: var(--zg-blue);
  }

  /* --- Copyright bar --- */
  .zg-footer-copy {
    font-size: 0.75rem;
    font-weight: 400;
    color: #000;
    margin: 0;
    text-align: center;
    border-top: 1px solid rgba(60, 80, 224, 0.15);
    padding-top: 16px;
  }

  /* --- Mobile --- */
  @media (max-width: 768px) {
    .zg-footer-inner {
      padding: 26px 16px 18px;
    }

    .zg-footer-main {
      flex-direction: column;
      gap: 20px;
    }

    .zg-footer-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }

    .zg-footer-logo {
      height: 36px;
    }

    .zg-footer-hq {
      font-size: 0.8125rem;
    }

    .zg-footer-tagline {
      font-size: 0.75rem;
    }

    .zg-footer-cta {
      font-size: 0.75rem;
      height: 26px;
      padding: 0 14px;
    }

    .zg-footer-links {
      gap: 2px;
    }

    .zg-footer-contact-item,
    .zg-footer-link {
      font-size: 0.75rem;
    }
  }
</style>
