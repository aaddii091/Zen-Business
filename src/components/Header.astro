---
import Button from './Button.astro';
---

<header class="zg-header">
  <nav class="zg-nav">
    <!-- Logo -->
    <a href="/" class="zg-logo" aria-label="Zengarden home">
      <img src="/images/zengarden-logo.png" alt="Zengarden" width="160" height="30" />
    </a>

    <!-- Nav links -->
    <ul class="zg-nav-links">
      <li><a href="/#for-schools">For Schools</a></li>
      <li><a href="/#for-universities">For Universities</a></li>
      <li><a href="/#compliance">Compliance</a></li>
      <li><a href="/#pricing">Pricing</a></li>
      <li><a href="/about">About</a></li>
    </ul>

    <!-- CTA buttons -->
    <div class="zg-nav-actions">
      <div class="zg-login-dropdown">
        <button class="zg-btn-ghost zg-login-trigger" aria-haspopup="true" aria-expanded="false" type="button">Login</button>
        <div class="zg-login-menu" role="menu" aria-label="Login options">
          <a
            href="https://client.zengarden.co.in/"
            class="zg-login-item"
            role="menuitem"
            target="_blank"
            rel="noopener noreferrer"
          >
            Login as User
          </a>
          <a
            href="https://control.zengarden.co.in/"
            class="zg-login-item"
            role="menuitem"
            target="_blank"
            rel="noopener noreferrer"
          >
            Login as Psychologist/Mentor
          </a>
        </div>
      </div>
      <Button variant="teal" href="https://calendly.com/aaddii091" size="sm" target="_blank" rel="noopener noreferrer">Book a Demo</Button>
    </div>

    <!-- Mobile menu toggle -->
    <button class="zg-hamburger" id="zg-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div class="zg-mobile-menu" id="zg-mobile-menu" hidden>
    <a href="/#for-schools">For Schools</a>
    <a href="/#for-universities">For Universities</a>
    <a href="/#compliance">Compliance</a>
    <a href="/#pricing">Pricing</a>
    <a href="/about">About</a>
    <Button variant="outline" href="https://client.zengarden.co.in/" size="md" class="mobile-btn" target="_blank" rel="noopener noreferrer">Login as User</Button>
    <Button variant="outline" href="https://control.zengarden.co.in/" size="md" class="mobile-btn" target="_blank" rel="noopener noreferrer">Login as Psychologist/Mentor</Button>
    <Button variant="teal" href="https://calendly.com/aaddii091" size="md" class="mobile-btn" target="_blank" rel="noopener noreferrer">Book a Demo</Button>
  </div>
</header>

<script>
  const toggle = document.getElementById('zg-menu-toggle');
  const menu = document.getElementById('zg-mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.hidden === false;
    if (menu) menu.hidden = open;
    toggle.setAttribute('aria-expanded', String(!open));
  });
</script>

<style>
  .zg-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--zg-nav-bg);
    border-bottom: 1px solid var(--zg-border-light);
  }

  .zg-nav {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
    height: 84px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .zg-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .zg-nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 8px;
    flex: 1;
  }

  .zg-nav-links a {
    padding: 10px 16px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--zg-dark);
    border-radius: 6px;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .zg-nav-links a:hover {
    background: var(--zg-hover-light);
    color: var(--zg-blue);
  }

  .zg-nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }


  .zg-login-dropdown {
    position: relative;
  }

  .zg-login-trigger {
    box-sizing: border-box;
    width: 100px;
    height: 38px;
    padding: 0 30px 0 0;
    border: 1px solid #3C50E0;
    border-radius: 24px;
    background: #FAFAFA;
    color: #3C50E0;
    font-family: 'Nunito', sans-serif;
    font-style: normal;
    font-weight: 600;
    font-size: 16px;
    line-height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    cursor: pointer;
  }

  .zg-login-trigger::after {
    content: "";
    position: absolute;
    right: 14px;
    top: 50%;
    width: 7px;
    height: 7px;
    border-right: 2px solid #3C50E0;
    border-bottom: 2px solid #3C50E0;
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  .zg-login-menu {
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 260px;
    background: white;
    border: 1px solid var(--zg-input-border);
    border-radius: var(--zg-radius-lg);
    box-shadow: var(--zg-shadow-lg);
    padding: 8px;
    margin-top: 8px;
    display: none;
    z-index: 120;
  }

  .zg-login-menu::before {
    content: "";
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
    background: transparent;
  }

  .zg-login-dropdown:hover .zg-login-menu,
  .zg-login-dropdown:focus-within .zg-login-menu {
    display: block;
  }

  .zg-login-item {
    display: block;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--zg-dark);
    white-space: nowrap;
  }

  .zg-login-item:hover {
    background: var(--zg-hover-light);
    color: var(--zg-blue);
  }


  .zg-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .zg-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--zg-dark);
    border-radius: 2px;
  }

  .zg-mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 24px 20px;
    border-top: 1px solid var(--zg-border-light);
  }

  .zg-mobile-menu a {
    padding: 10px 12px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--zg-dark);
    border-radius: var(--zg-radius-sm);
  }

  .zg-mobile-menu :global(.mobile-btn) {
    text-align: center;
    margin-top: 4px;
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .zg-nav-links,
    .zg-nav-actions {
      display: none;
    }

    .zg-hamburger {
      display: flex;
    }
  }

</style>
